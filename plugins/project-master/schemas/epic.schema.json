{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Epic sidecar YAML",
  "type": "object",
  "required": ["id", "type", "title", "priority", "module", "owner", "status", "created"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z]{2,6}-E[0-9]{2}$"
    },
    "type": { "const": "epic" },
    "title": { "type": "string", "minLength": 5 },
    "priority": { "type": "string", "enum": ["P1", "P2", "P3"] },
    "module": {
      "type": "string",
      "minLength": 1,
      "description": "Module slug. Projects define their own module list in .pm-config.json."
    },
    "owner": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["backlog", "in-progress", "done", "blocked", "superseded"]
    },
    "stories": { "type": "array", "items": { "type": "string" } },
    "depends-on": { "type": "array", "items": { "type": "string" } },
    "blocks": { "type": "array", "items": { "type": "string" } },
    "jira_key": { "type": ["string", "null"] },
    "jira_sync_at": { "type": ["string", "null"] },
    "jira_sync_hash": { "type": ["string", "null"] },
    "stories_total": { "type": "integer", "minimum": 0 },
    "stories_done": { "type": "integer", "minimum": 0 },
    "progress_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
    "superseded_by": { "type": ["string", "null"] },
    "supersedes": { "type": ["string", "null"] },
    "created": { "type": "string", "format": "date" },
    "created_by": { "type": "string" },
    "updated": { "type": "string", "format": "date" },
    "updated_by": { "type": "string" }
  }
}
